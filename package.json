{
  "name": "veeam-mtr",
  "version": "1.0.0",
  "description": "API de Monitoramento do Veeam Backup.",
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "start:dev": "tsx watch src/server.ts",
    "build": "tsup src --out-dir build",
    "build:v2": "tsup",
    "start:prod": "node build/server.js",
    "auth": "tsx src/veeamAuth.ts",
    "start:pm2": "pm2 start ecosystem.config.cjs && pm2 save > /dev/null 2>&1",
    "start:pm3": "pm2 start ecosystem.config.cjs --no-attach && pm2 save",
    "stop:pm2": "pm2 stop veeam-backup-monitor",
    "restart:pm2": "pm2 restart veeam-backup-monitor --no-attach && pm2 save",
    "delete:pm2": "pm2 delete veeam-backup-monitor && pm2 save",
    "logs:pm2": "pm2 logs veeam-backup-monitor",
    "test": "vitest",
    "test:unit": "vitest run unit",
    "test:e2e": "vitest run e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "diagnose:vbr": "tsx scripts/diagnose-vbr-connection.ts"
  },
  "keywords": [
    "veeam",
    "backup",
    "monitoramento",
    "api",
    "fastify",
    "nodejs",
    "typescript"
  ],
  "author": "2° Ten Guedes",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "fastify": "^5.4.0",
    "fastify-metrics": "^12.1.0",
    "node-fetch": "^2.7.0",
    "prom-client": "^15.1.3",
    "qs": "^6.14.1"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@types/node-fetch": "^2.6.12",
    "dotenv": "^17.2.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18",
    "@types/qs": "^6.14.0",
    "@vitest/ui": "^4.0.18"
  }
}